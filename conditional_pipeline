pipeline {
    agent any

    stages {
        stage('Test') {
            steps {
                script {
                    def testResult = sh(script: 'sh test.sh', returnStatus: true)

                    if (testResult == 0) {
                        echo 'Tests passed'
                    } else {
                        echo 'Tests failed'
                        error('Stopping pipeline because tests failed')
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                echo "Deploying application..."
            }
        }
    }

    post {
    success {
        emailext(
            to:'meghak7295@gmail.com',
            subject: "SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
            body: "Tests passed and deployment completed successfully."
        )
    }
    failure {
        emailext(
            to: 'meghak7295@gmail.com',
            subject: "FAILURE: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
            body: "Tests failed, so deployment was stopped."
        )
    }
}
}