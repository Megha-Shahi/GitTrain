pipeline {
    agent any

    environment {
        APP_DIR = "${WORKSPACE}/myapp"
        RELEASES_DIR = "${WORKSPACE}/myapp/releases"
        CURRENT_LINK = "${WORKSPACE}/myapp/current"
        LAST_SUCCESS_FILE = "${WORKSPACE}/last_successful_build.txt"
        TO_MAIL = "yourmail@example.com"
    }

    stages {
        stage('Deploy Current Build') {
            steps {
                sh '''
                    mkdir -p "$RELEASES_DIR/build-$BUILD_NUMBER"
                    echo "This is build $BUILD_NUMBER" > "$RELEASES_DIR/build-$BUILD_NUMBER/app.txt"
                    ln -sfn "$RELEASES_DIR/build-$BUILD_NUMBER" "$CURRENT_LINK"
                    echo "Deployed build-$BUILD_NUMBER"
                '''
            }
        }

        stage('Simulate Result') {
            steps {
                sh 'exit 0'
            }
        }
    }

    post {
        success {
            echo "Build succeeded"
            sh 'echo $BUILD_NUMBER > "$LAST_SUCCESS_FILE"'

            emailext(
                to: "${TO_MAIL}",
                subject: "Jenkins Build Success: ${JOB_NAME} #${BUILD_NUMBER}",
                body: """Build succeeded.

Job: ${JOB_NAME}
Build: ${BUILD_NUMBER}
Current build is now the last successful build.
"""
            )
        }

        failure {
            script {
                def lastOk = sh(
                    script: 'cat "$LAST_SUCCESS_FILE"',
                    returnStdout: true
                ).trim()

                echo "Build failed. Rolling back to build ${lastOk}"

                sh '''
                    LAST_OK=$(cat "$LAST_SUCCESS_FILE")
                    ln -sfn "$RELEASES_DIR/build-$LAST_OK" "$CURRENT_LINK"
                    echo "After rollback, current points to:"
                    readlink -f "$CURRENT_LINK"
                '''

                emailext(
                    to: "${TO_MAIL}",
                    subject: "Jenkins Build Failed and Rolled Back: ${JOB_NAME} #${BUILD_NUMBER}",
                    body: """Build failed.

Job: ${JOB_NAME}
Failed build: ${BUILD_NUMBER}
Rolled back to build: ${lastOk}
"""
                )
            }
        }
    }
}