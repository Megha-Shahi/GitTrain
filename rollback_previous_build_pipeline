pipeline {
    agent any
   

   //WORKSPACE is the Jenkins job folder for this project.
    environment {
        APP_DIR = "${WORKSPACE}/myapp"
        //this means: inside myapp, create a releases folder.
        RELEASES_DIR = "${WORKSPACE}/myapp/releases"
        //It will point to the currently active build
        CURRENT_LINK = "${WORKSPACE}/myapp/current"
        //This is a text file where we store the last successful build number.
        LAST_SUCCESS_FILE = "${WORKSPACE}/last_successful_build.txt"
        TO_MAIL = "meghak7295@example.com"
    }

    stages {
        stage('Deploy Current Build') {
            steps {
                sh '''
                    mkdir -p "$RELEASES_DIR/build-$BUILD_NUMBER"
                    # Put app files into the build folder
                    echo "This is build $BUILD_NUMBER" > "$RELEASES_DIR/build-$BUILD_NUMBER/app.txt"
                    # ln -s creates a symbolic link
                    # -f: replace if current already exists
                    # -n: treat current as a file, not a directory
                    ln -sfn "$RELEASES_DIR/build-$BUILD_NUMBER" "$CURRENT_LINK"
                    echo "Deployed build-$BUILD_NUMBER"
                '''
            }
        }

        stage('Simulate Result') {
            steps {
                sh 'exit 0'
            }
        }
    }

    post {
        success {
            echo "Build succeeded"
            sh 'echo $BUILD_NUMBER > "$LAST_SUCCESS_FILE"'

            emailext(
                to: "${TO_MAIL}",
                subject: "Jenkins Build Success: ${JOB_NAME} #${BUILD_NUMBER}",
                body: """Build succeeded.

Job: ${JOB_NAME}
Build: ${BUILD_NUMBER}
Current build is now the last successful build.
"""
            )
        }

        failure {
            script {
                def lastOk = sh(
                    script: 'if [ -f "$LAST_SUCCESS_FILE" ]; then cat "$LAST_SUCCESS_FILE"; else echo "none"; fi',
                    returnStdout: true
                ).trim()

                if (lastOk == 'none') {
                    echo "No previous successful build found. Cannot roll back."
                    return
                }

                echo "Build failed. Rolling back to build ${lastOk}"

                sh """
                    # moves the current symlink back to the last good build
                    ln -sfn "$RELEASES_DIR/build-${lastOk}" "$CURRENT_LINK"
                    echo "After rollback, current points to:"
                    readlink -f "$CURRENT_LINK"
                """

                emailext(
                    to: "${TO_MAIL}",
                    subject: "Jenkins Build Failed and Rolled Back: ${JOB_NAME} #${BUILD_NUMBER}",
                    body: """Build failed.

Job: ${JOB_NAME}
Failed build: ${BUILD_NUMBER}
Rolled back to build: ${lastOk}
"""
                )
            }
        }
    }
}